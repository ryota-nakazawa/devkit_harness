{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_COMMAND\" | grep -Eq '(rm -rf [/~]|rm -rf [*]|curl.*[|].*sh|wget.*[|].*bash|mkfs|sudo )'; then echo 'BLOCKED: dangerous command pattern'; exit 2; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATHS\" | grep -q 'output/.*[.]html$'; then for f in $CLAUDE_FILE_PATHS; do [ -f \"$f\" ] && grep -q '<html' \"$f\" && grep -q '</html>' \"$f\" || echo \"WARN: $f may be incomplete HTML\"; grep -q '{{' \"$f\" && echo \"WARN: unfilled placeholder in $f\"; done; fi"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(open output/*)",
      "Bash(cp -r templates/*)",
      "Bash(mkdir -p output/*)",
      "Bash(mkdir -p specs)",
      "Bash(mkdir -p history)",
      "Write(output/**)",
      "Write(specs/**)",
      "Write(history/**)",
      "Edit(output/**)",
      "Edit(history/index.jsonl)"
    ],
    "deny": [
      "Write(/**)",
      "Write(~/**)",
      "Write(../**)",
      "Edit(/**)",
      "Edit(~/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)"
    ]
  }
}
